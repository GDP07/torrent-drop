{
  "name": "torrentdrop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A clean desktop torrent client: paste a magnet link, download from the full BitTorrent swarm, everything stays on your machine.",
  "license": "MIT",
  "homepage": "https://github.com/GDP07/torrent-drop#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/GDP07/torrent-drop.git"
  },
  "bugs": {
    "url": "https://github.com/GDP07/torrent-drop/issues"
  },
  "keywords": [
    "torrent",
    "bittorrent",
    "webtorrent",
    "electron",
    "magnet",
    "download"
  ],
  "main": "electron/main.cjs",
  "scripts": {
    "start": "UV_THREADPOOL_SIZE=64 node server.js",
    "desktop": "electron electron/main.cjs",
    "icons": "node build/gen-tray.cjs && bash build/make-icons.sh",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "webtorrent": "^2.6.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8"
  },
  "author": "GDP07",
  "build": {
    "appId": "com.torrentdrop.app",
    "productName": "TorrentDrop",
    "asar": false,
    "npmRebuild": false,
    "afterPack": "./build/afterPack.cjs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "server.js",
      "public/**",
      "package.json",
      "node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
